

<JuegoSeccion>:
    id: float_layout
    size_hint: 1, 1
    pos_hint: {'center_x': 0.5, 'center_y': 0.5}

    Image:
        id: background_image
        pos_hint: {'x': 0,'y': 0}
        source: 'src/assets/imagen/fondo.jpg'
        size_hint: 1, 1
        fit_mode: 'fill'

    ScrollView:
        id: scroll_view
        pos_hint: {'center_y': 0.5, 'center_x': 0.5}
        size_hint: (0.95, 0.7)
        bar_width: 0
        do_scroll_y: False
        # padding: dp(0), dp(40)

        BoxLayout:
            size_hint: (1.335, 1)
            JuegoSeccionItem:
                background_id: background_image
                imagen: 'src/assets/imagen/icons_poker.png'
                titulo: 'Poker'
            BoxLayout:
                size_hint: (0.025, 1)
            JuegoSeccionItem:
                background_id: background_image
                imagen: 'src/assets/imagen/icons_blackjack.png'
                titulo: 'Blackjack'
            BoxLayout:
                size_hint: (0.025, 1)
            JuegoSeccionItem:
                background_id: background_image
                imagen: 'src/assets/imagen/icons_knuckleBones.png'
                titulo: 'knuckleBones'
            BoxLayout:
                size_hint: (0.025, 1)
            JuegoSeccionItem:
                background_id: background_image
                imagen: 'src/assets/imagen/icons_money.png'
                titulo: 'Ruleta'